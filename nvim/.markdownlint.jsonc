{
  // Line length — too strict for prose/docs
  "MD013": false,
  // Blank lines around headings
  "MD022": false,
  // Single H1 per document
  "MD025": false,
  // No trailing punctuation in headings
  "MD026": false,
  // Blank lines around lists
  "MD032": false,
  // No inline HTML
  "MD033": false,
  // Multiple consecutive blank lines
  "MD012": false,
  // Unordered list style — allow consistent (dash or asterisk)
  "MD004": { "style": "consistent" }
}
